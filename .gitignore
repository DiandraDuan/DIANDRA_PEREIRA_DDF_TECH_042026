# Ambiente virtual
venv/
.venv/

# Cache Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter / sistema
.ipynb_checkpoints/
.DS_Store
Thumbs.db

# Dados brutos e intermediários
data/raw/*
